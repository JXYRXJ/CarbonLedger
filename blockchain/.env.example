# Private key of the deployer wallet (do NOT prefix with 0x)
PRIVATE_KEY=your_private_key_here

# Polygon Amoy RPC URL (e.g. from Alchemy, Infura, or public RPC)
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/your_alchemy_api_key

# Polygonscan API Key for contract source code verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Address of the deployer (for informational purposes)
DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000
